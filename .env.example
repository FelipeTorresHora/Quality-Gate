# App
APP_ENV=development
APP_NAME=PR Quality Gate Dashboard
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql+psycopg://pr_quality:pr_quality@postgres:5432/pr_quality

# GitHub
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=change-me-to-a-random-secret
GITHUB_DEFAULT_BASE_BRANCH=main
GITHUB_STATUS_CONTEXT=ai-quality-gate

# OpenAI / LangChain
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pr-quality-dashboard

# Runner placeholders
WORKDIR=/tmp/pr-quality-dashboard
COMMAND_TIMEOUT_SECONDS=600
KEEP_WORKDIR=false

# Coverage defaults
DEFAULT_TEST_COMMAND=pytest --cov=src --cov-report=xml --cov-report=term
DEFAULT_COVERAGE_XML_PATH=coverage.xml
DEFAULT_MIN_TOTAL_COVERAGE=80
DEFAULT_MAX_COVERAGE_DROP=0
DEFAULT_MIN_CHANGED_FILES_COVERAGE=75

# Security defaults
SECURITY_FAIL_ON=critical,high
RUN_BANDIT=true
RUN_SEMGREP=true
RUN_DETECT_SECRETS=true
RUN_DEPENDENCY_AUDIT=true

# Technical debt defaults
MAX_FUNCTION_LINES=80
MAX_COMPLEXITY=10
FAIL_ON_NEW_TODO=true

# Frontend
VITE_API_BASE_URL=http://localhost:8000
